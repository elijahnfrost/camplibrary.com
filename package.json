{
  "name": "camp-library",
  "version": "1.0.0",
  "private": true,
  "description": "Camp Library — a warm, hand-drawn catalog of camp games, crafts, and songs, with a calendar for planning the camp week.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "lint:design-tokens": "node scripts/check-design-tokens.mjs",
    "lint:css-hygiene": "node scripts/check-css-hygiene.mjs",
    "lint:boundaries": "depcruise app components lib proxy.ts",
    "lint:file-size": "node scripts/check-file-size.mjs",
    "report:deadcode": "knip",
    "report:deps": "depcheck",
    "report:exports": "ts-prune",
    "report:css": "node scripts/report-unused-css.mjs",
    "env:check": "node scripts/check-env.mjs",
    "invite:create": "node scripts/create-invite-code.mjs",
    "camp:mcp": "tsx tools/camp-mcp/src/server.ts",
    "camp:cli": "tsx tools/camp-mcp/src/cli.ts",
    "camp:typecheck": "tsc -p tools/camp-mcp/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.4.2",
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "ical-generator": "^6.0.1",
    "next": "^16.1.0",
    "pagedjs": "^0.4.3",
    "postgres": "^3.4.9",
    "react": "^19.0.0",
    "react-colorful": "^5.7.0",
    "react-dom": "^19.0.0",
    "svix": "^1.95.1",
    "uqr": "^0.1.3"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.18.1",
    "@playwright/test": "^1.61.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "depcheck": "^1.4.7",
    "dependency-cruiser": "^18.0.0",
    "happy-dom": "^20.10.6",
    "knip": "^6.24.0",
    "postcss": "8.5.15",
    "ts-prune": "^0.10.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^4.1.8",
    "zod": "^3.23.8"
  },
  "overrides": {
    "postcss": "8.5.15"
  }
}
