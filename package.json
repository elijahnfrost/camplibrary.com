{
  "name": "camp-library",
  "version": "1.0.0",
  "private": true,
  "description": "Camp Library — a warm, hand-drawn catalog of camp games, crafts, and songs, with a calendar for planning the camp week.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "lint:design-tokens": "node scripts/check-design-tokens.mjs",
    "env:check": "node scripts/check-env.mjs",
    "invite:create": "node scripts/create-invite-code.mjs"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.4.2",
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "ical-generator": "^6.0.1",
    "next": "^16.1.0",
    "postgres": "^3.4.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "svix": "^1.95.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "postcss": "8.5.15"
  }
}
