# Camp Library backend and deployment configuration.
# Copy to .env.local for local development, or add the same keys in Vercel.
# Never commit .env.local or real secret values.

# Public app URL. This value is safe for the browser.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Required before enabling server-side auth/session signing.
# Generate with:
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET=

# Optional Clerk auth keys if Clerk is selected as the auth provider.
# The publishable key is public. The secret and webhook secret are server-only.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# Optional persistence/database layer.
# Use DATABASE_URL if the backend lands on Vercel Postgres/Neon or another SQL store.
DATABASE_URL=

# Optional Cloudflare backend bridge.
# Use these if a Worker/D1/KV API owns synced libraries, schedules, ratings, and custom entries.
CAMP_LIBRARY_API_URL=
CAMP_LIBRARY_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_DATABASE_ID=
CLOUDFLARE_API_TOKEN=
