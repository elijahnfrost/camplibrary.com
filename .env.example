# Camp Library backend and deployment configuration.
# Copy to .env.local for local development, or add the same keys in Vercel.
# Never commit .env.local or real secret values.

# Public app URL. This value is safe for the browser.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Required secrets.
# Generate with:
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET=
INVITE_CODE_SECRET=

# Required Postgres database for usage-limited invite codes.
DATABASE_URL=

# Clerk auth keys. Enable Google and email/password in the Clerk Dashboard.
# The publishable key is public. The secret and webhook secret are server-only.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# Optional admin token for generating/listing invite codes through /api/invite-codes.
INVITE_CODE_ADMIN_TOKEN=

# Optional Cloudflare backend bridge.
# Use these if a Worker/D1/KV API owns synced libraries, schedules, ratings, and custom entries.
CAMP_LIBRARY_API_URL=
CAMP_LIBRARY_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_DATABASE_ID=
CLOUDFLARE_API_TOKEN=
